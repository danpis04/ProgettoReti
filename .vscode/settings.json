{
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.recipes": [
    {
      "name": "pdflatex.exe twice (MiKTeX)",
      "tools": [
        "pdflatex.exe (MiKTeX)",
        "pdflatex.exe (MiKTeX)"
      ]
    },
    {
      "name": "latexmk.exe (MiKTeX)",
      "tools": [
        "latexmk.exe (MiKTeX)"
      ]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex.exe (MiKTeX)",
      "command": "/mnt/c/Users/danie/AppData/Local/Programs/MiKTeX/miktex/bin/x64/pdflatex.exe",
      "args": [
