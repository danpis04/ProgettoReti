    {
      "name": "latexmk.exe (MiKTeX)",
      "command": "/mnt/c/Users/danie/AppData/Local/Programs/MiKTeX/miktex/bin/x64/latexmk.exe",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "%DOCFILE_EXT%"
      ]
    }
  ]
